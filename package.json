    "lucide-react": "^1.21.0",
    "multer": "^2.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "reactflow": "^11.11.4",
    "recharts": "^3.9.0",
    "simple-git": "^3.28.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.0",
    "oxlint": "^1.69.0",
    "tailwindcss": "^4.3.1",
    "vite": "^8.1.0"
