{
  "name": "horizon-ai-engineering",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server/index.js",
    "dev:full": "concurrently -k -n web,api -c cyan,magenta \"vite --open\" \"node server/index.js\"",
